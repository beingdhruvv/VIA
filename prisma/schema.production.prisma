generator client {
  provider = "prisma-client-js"
}

// Production schema for the DigitalOcean droplet.
// Local development intentionally keeps prisma/schema.prisma on SQLite.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  language     String   @default("en")
  createdAt    DateTime @default(now()) @map("created_at")

  trips     Trip[]
  tripNotes TripNote[]

  @@map("users")
}

model Trip {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  coverUrl    String?  @map("cover_url")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  totalBudget Float?   @map("total_budget")
  isPublic    Boolean  @default(false) @map("is_public")
  publicSlug  String?  @unique @map("public_slug")
  status      String   @default("PLANNING")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops        TripStop[]
  expenses     Expense[]
  packingItems PackingItem[]
  notes        TripNote[]
  sharedLinks  SharedLink[]

  @@map("trips")
}

model City {
  id              String  @id @default(uuid())
  name            String
  country         String
  region          String
  costIndex       Float   @map("cost_index")
  popularityScore Int     @map("popularity_score")
  imageUrl        String? @map("image_url")
  latitude        Float
  longitude       Float

  stops      TripStop[]
  activities Activity[]

  @@map("cities")
}

model TripStop {
  id         String   @id @default(uuid())
  tripId     String   @map("trip_id")
  cityId     String   @map("city_id")
  orderIndex Int      @map("order_index")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  notes      String?

  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city       City           @relation(fields: [cityId], references: [id])
  activities StopActivity[]
  expenses   Expense[]
  tripNotes  TripNote[]

  @@map("trip_stops")
}

model Activity {
  id            String  @id @default(uuid())
  cityId        String  @map("city_id")
  name          String
  description   String
  category      String
  estimatedCost Float   @map("estimated_cost")
  durationHours Float   @map("duration_hours")
  imageUrl      String? @map("image_url")
  rating        Float

  city      City           @relation(fields: [cityId], references: [id])
  stopItems StopActivity[]

  @@map("activities")
}

model StopActivity {
  id            String    @id @default(uuid())
  stopId        String    @map("stop_id")
  activityId    String    @map("activity_id")
  scheduledDate DateTime? @map("scheduled_date")
  scheduledTime String?   @map("scheduled_time")
  actualCost    Float?    @map("actual_cost")

  stop     TripStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id])

  @@unique([stopId, activityId])
  @@map("stop_activities")
}

model Expense {
  id          String   @id @default(uuid())
  tripId      String   @map("trip_id")
  stopId      String?  @map("stop_id")
  category    String
  amount      Float
  description String
  date        DateTime

  trip Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop TripStop? @relation(fields: [stopId], references: [id])

  @@map("expenses")
}

model PackingItem {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  name      String
  category  String
  isPacked  Boolean  @default(false) @map("is_packed")
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("packing_items")
}

model TripNote {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  stopId    String?  @map("stop_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trip Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop TripStop? @relation(fields: [stopId], references: [id])
  user User      @relation(fields: [userId], references: [id])

  @@map("trip_notes")
}

model SharedLink {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  slug      String   @unique
  views     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("shared_links")
}
