generator client {
  provider = "prisma-client-js"
}

// LOCAL DEV: SQLite (zero setup). PRODUCTION: switch to postgresql + update DATABASE_URL
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Models ──────────────────────────────────────────────────────────────────
// Enums are stored as String in SQLite (Prisma enums require PostgreSQL)
// Valid values: TripStatus: PLANNING | ACTIVE | COMPLETED
//               ActivityCategory: SIGHTSEEING | FOOD | ADVENTURE | CULTURE | SHOPPING | WELLNESS
//               ExpenseCategory: TRANSPORT | STAY | FOOD | ACTIVITIES | MISC
//               PackingCategory: CLOTHING | DOCUMENTS | ELECTRONICS | TOILETRIES | MISC

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  role         String   @default("USER") // USER | ADMIN | SUPER_ADMIN
  language     String   @default("en")
  homeCity     String?  @map("home_city")
  homeCountry  String?  @map("home_country")
  createdAt    DateTime @default(now()) @map("created_at")
  storageUsed  Int      @default(0) @map("storage_used") // Track bytes used

  trips    Trip[]
  memories Memory[]
  tripNotes TripNote[]
  collaboratingIn TripCollaborator[]
  paidExpenses    Expense[]          @relation("PayerRelation")
  expenseSplits   ExpenseSplit[]
  tastes          UserTaste[]

  @@map("users")
}

model Trip {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  coverUrl    String?  @map("cover_url")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  totalBudget Float?   @map("total_budget")
  isPublic    Boolean  @default(false) @map("is_public")
  publicSlug  String?  @unique @map("public_slug")
  /// TripStatus: PLANNING | ACTIVE | COMPLETED
  status      String   @default("PLANNING")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops        TripStop[]
  expenses     Expense[]
  packingItems PackingItem[]
  notes        TripNote[]
  sharedLinks  SharedLink[]
  collaborators TripCollaborator[]
  memories      Memory[]

  @@map("trips")
}

model City {
  id              String @id @default(uuid())
  name            String
  country         String
  region          String
  costIndex       Float  @map("cost_index")
  popularityScore Int    @map("popularity_score")
  imageUrl        String? @map("image_url")
  latitude        Float
  longitude       Float

  stops      TripStop[]
  activities Activity[]
  tastes     UserTaste[]

  @@map("cities")
}

model TripStop {
  id         String   @id @default(uuid())
  tripId     String   @map("trip_id")
  cityId     String   @map("city_id")
  orderIndex Int      @map("order_index")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  notes      String?

  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city       City           @relation(fields: [cityId], references: [id])
  activities StopActivity[]
  expenses   Expense[]
  tripNotes  TripNote[]

  @@map("trip_stops")
}

model Activity {
  id            String  @id @default(uuid())
  cityId        String  @map("city_id")
  name          String
  description   String
  /// ActivityCategory: SIGHTSEEING | FOOD | ADVENTURE | CULTURE | SHOPPING | WELLNESS
  category      String
  estimatedCost Float   @map("estimated_cost")
  durationHours Float   @map("duration_hours")
  imageUrl      String? @map("image_url")
  rating        Float

  city      City           @relation(fields: [cityId], references: [id])
  stopItems StopActivity[]

  @@map("activities")
}

model StopActivity {
  id            String    @id @default(uuid())
  stopId        String    @map("stop_id")
  activityId    String    @map("activity_id")
  scheduledDate DateTime? @map("scheduled_date")
  scheduledTime String?   @map("scheduled_time")
  actualCost    Float?    @map("actual_cost")

  stop     TripStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id])

  @@unique([stopId, activityId])
  @@map("stop_activities")
}

model Expense {
  id          String   @id @default(uuid())
  tripId      String   @map("trip_id")
  stopId      String?  @map("stop_id")
  payerId     String?  @map("payer_id")
  /// ExpenseCategory: TRANSPORT | STAY | FOOD | ACTIVITIES | MISC
  category    String
  amount      Float
  description String
  date        DateTime

  trip   Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop   TripStop?      @relation(fields: [stopId], references: [id])
  payer  User?          @relation("PayerRelation", fields: [payerId], references: [id])
  splits ExpenseSplit[]

  @@map("expenses")
}

model PackingItem {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  name      String
  /// PackingCategory: CLOTHING | DOCUMENTS | ELECTRONICS | TOILETRIES | MISC
  category  String
  isPacked  Boolean  @default(false) @map("is_packed")
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("packing_items")
}

model TripNote {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  stopId    String?  @map("stop_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trip Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop TripStop? @relation(fields: [stopId], references: [id])
  user User      @relation(fields: [userId], references: [id])

  @@map("trip_notes")
}

model SharedLink {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  slug      String   @unique
  views     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("shared_links")
}

model TripCollaborator {
  id     String @id @default(uuid())
  tripId String @map("trip_id")
  userId String @map("user_id")
  role   String @default("EDITOR") // OWNER | EDITOR | VIEWER

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@map("trip_collaborators")
}

model ExpenseSplit {
  id        String @id @default(uuid())
  expenseId String @map("expense_id")
  userId    String @map("user_id")
  amount    Float

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

model UserTaste {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  cityId    String   @map("city_id")
  type      String   // LIKE | DISLIKE | SAVE
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
  @@map("user_tastes")
}

model Memory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  tripId       String?  @map("trip_id")
  imageUrl     String   @map("image_url")
  thumbnailUrl String?  @map("thumbnail_url")
  caption      String?
  fileName     String   @map("file_name")
  fileSize     Int      @map("file_size") // size in bytes
  mimeType     String   @map("mime_type")
  
  // Metadata from EXIF
  takenAt      DateTime? @map("taken_at")
  latitude     Float?
  longitude    Float?
  locationName String?   @map("location_name")
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@map("memories")
}
