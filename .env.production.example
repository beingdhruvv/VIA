# Copy to /var/www/via/.env.production on the server (never commit the filled file).
# Use the same keys in GitHub Actions secrets where applicable.

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://via_user:REPLACE_WITH_STRONG_DB_PASSWORD@localhost:5432/via_db

# Must match the public URL users hit (https://your-domain.com — no trailing slash).
NEXTAUTH_URL=https://REPLACE_WITH_PUBLIC_HOST
AUTH_URL=https://REPLACE_WITH_PUBLIC_HOST
NEXTAUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
AUTH_SECRET=REPLACE_WITH_SAME_VALUE_AS_NEXTAUTH_SECRET

GEODB_API_KEY=REPLACE_WITH_RAPIDAPI_GEODB_KEY

# Seed reference cities/activities during deploy. Set to 0 after first production seed if desired.
RUN_SEED_ON_DEPLOY=1

# Optional: Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Firebase web SDK (Google Sign-In). Prefer these on the server — read at runtime, no rebuild needed
# after you add keys (same values as in Firebase Console → Project settings → Your apps).
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MEASUREMENT_ID=

# Optional: duplicate for client bundle if you want Google without /api/config (requires rebuild when set)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
