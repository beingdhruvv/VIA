# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next*
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.local
.env.production
.env*.local

# Ops notes with real hosts/keys — copy from LOCAL_OPERATIONS.md.template
LOCAL_OPERATIONS.md

# Presenter-only demo script (never commit)
DOCS/VIDEO_DEMO_SCRIPT.md

# SQLite dev database — local only, never commit
*.db
*.db-journal
*.db-wal
*.db-shm
*.db
*.db-journal
*.db-wal
*.db-shm
prisma/dev.db
prisma/prisma/dev.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
